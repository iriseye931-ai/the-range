#!/usr/bin/env bash
# Quick health check for the AI mesh — all services, pass/fail, under 3s
set -uo pipefail

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

ok()   { printf " ${GREEN}OK${NC}   %s\n" "$1"; }
fail() { printf " ${RED}FAIL${NC} %s\n" "$1"; }
warn() { printf " ${YELLOW}WARN${NC} %s\n" "$1"; }

check() {
  local name="$1" url="$2" timeout="${3:-2}"
  if curl -sf --max-time "$timeout" "$url" -o /dev/null 2>/dev/null; then
    ok "$name"
    return 0
  else
    fail "$name ($url)"
    return 1
  fi
}

echo "Mesh health — $(date '+%H:%M:%S')"
echo "---"

PASS=0; FAIL=0

check_svc() {
  if check "$@"; then ((PASS++)); else ((FAIL++)); fi
}

check_svc "OpenViking memory  " "http://127.0.0.1:1933/health"
# Memory MCP is SSE/socket, not HTTP — check port is open
if nc -z -w2 127.0.0.1 2033 2>/dev/null; then
  ((PASS++)); ok "Memory MCP (2033)  "
else
  ((FAIL++)); fail "Memory MCP (2033)   (port closed)"
fi
check_svc "MLX 35B (8081)     " "http://127.0.0.1:8081/v1/models"
check_svc "MLX 9B  (8083)     " "http://127.0.0.1:8083/v1/models"
check_svc "AI Maestro (23000) " "http://127.0.0.1:23000/api/agents"
check_svc "Screenpipe (3030)  " "http://127.0.0.1:3030/health"
check_svc "Ollama (11434)     " "http://127.0.0.1:11434/api/tags"

# Whisper STT (8082) — optional
if curl -sf --max-time 2 "http://127.0.0.1:8082/" -o /dev/null 2>/dev/null; then
  ((PASS++)); ok "Whisper STT (8082) "
else
  warn "Whisper STT (8082)  (not running)"
fi

echo "---"
echo "$PASS up, $FAIL down"
[[ $FAIL -eq 0 ]] && exit 0 || exit 1
