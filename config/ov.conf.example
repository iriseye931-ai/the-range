{
  "server": {
    "host": "0.0.0.0",
    "port": 1933,
    "root_api_key": "your-api-key-here",
    "cors_origins": ["*"]
  },
  "storage": {
    "workspace": "/path/to/.openviking/data"
  },
  "embedding": {
    "dense": {
      "provider": "openai",
      "model": "text-embedding-nomic-embed-text-v1.5",
      "api_base": "http://YOUR_LLM_HOST:PORT/v1",
      "api_key": "local",
      "dimension": 768
    }
  },
  "vlm": {
    "provider": "openai",
    "model": "your-model-name",
    "api_base": "http://YOUR_LLM_HOST:PORT/v1",
    "api_key": "local",
    "temperature": 0.0,
    "max_tokens": 4096
  }
}
