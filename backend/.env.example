# Mission Control Backend — environment config
# Copy to .env and edit before running

# OpenViking memory server
OPENVIKING_URL=http://127.0.0.1:1933
OPENVIKING_KEY=your-api-key-here

# MCP servers
MEMORY_MCP_URL=http://127.0.0.1:2033/mcp
OPENCLAW_MCP_URL=http://127.0.0.1:2034/mcp   # optional — remove if not using OpenClaw

# AI Maestro (optional agent orchestrator)
AIMAESTRO_URL=http://localhost:23000

# Local LLM (OpenAI-compatible endpoint)
LLM_URL=http://localhost:6698/v1

# Hermes cron jobs file
CRON_JOBS_PATH=~/.hermes/cron/jobs.json

# Your lead agent's name (shown in chat UI)
AGENT_NAME=Atlas

# Polling interval in seconds
POLL_INTERVAL=10
