<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  OpenViking server LaunchAgent — auto-starts on login, restarts on crash.

  Install:
    cp local.openviking-server.plist ~/Library/LaunchAgents/
    # Edit paths and env vars below
    launchctl load ~/Library/LaunchAgents/local.openviking-server.plist
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>local.openviking-server</string>

    <key>ProgramArguments</key>
    <array>
        <string>/path/to/.openviking/venv/bin/python</string>
        <string>-c</string>
        <string>import uvicorn; from openviking.server import create_app; app = create_app(); uvicorn.run(app, host='0.0.0.0', port=1933)</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <key>OPENVIKING_CONFIG_FILE</key>
        <string>/path/to/.openviking/ov.conf</string>
    </dict>

    <key>WorkingDirectory</key>
    <string>/path/to/.openviking/data</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <key>StandardOutPath</key>
    <string>/path/to/.openviking/logs/server.log</string>

    <key>StandardErrorPath</key>
    <string>/path/to/.openviking/logs/server.error.log</string>
</dict>
</plist>
